# Shopify App Credentials
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SHOPIFY_APP_URL=https://your-app.apprunner.aws
SHOP=your-store.myshopify.com
SHOPIFY_ADMIN_API_ACCESS_TOKEN=shpat_your_token_here
SCOPES=write_products,read_products,write_inventory,read_inventory,write_orders,read_orders

# Session Secret (generate a random string)
SESSION_SECRET=change-this-to-a-random-secret-string

# Cron Security (used by /api/trigger-sync-inventory)
CRON_SECRET=change-this-to-a-strong-cron-secret

# Node Environment
NODE_ENV=development
PORT=3000

# Database URL (PostgreSQL)
# For local development, you can use a local PostgreSQL or connect to Railway
DATABASE_URL="postgresql://user:password@localhost:5432/bundles?schema=public"
